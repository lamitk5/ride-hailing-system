<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Fluid Motion Typography System -->
    <style name="TextAppearance.FluidMotion.DisplaySmall" parent="TextAppearance.AppCompat">
        <item name="android:textSize">36sp</item>
        <item name="android:fontFamily">sans-serif-condensed-medium</item>
        <item name="android:textColor">@color/on_surface</item>
    </style>

    <style name="TextAppearance.FluidMotion.HeadlineLarge" parent="TextAppearance.AppCompat">
        <item name="android:textSize">32sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/on_surface</item>
    </style>

    <style name="TextAppearance.FluidMotion.HeadlineSmall" parent="TextAppearance.AppCompat">
        <item name="android:textSize">24sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/on_surface</item>
    </style>

    <style name="TextAppearance.FluidMotion.BodyMedium" parent="TextAppearance.AppCompat">
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">@color/on_surface</item>
    </style>

    <style name="TextAppearance.FluidMotion.LabelMedium" parent="TextAppearance.AppCompat">
        <item name="android:textSize">12sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/on_surface_variant</item>
    </style>

    <!-- UI Component Styles -->
    <style name="Widget.FluidMotion.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/primary_container</item>
        <item name="android:textColor">@color/on_primary</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <style name="Widget.FluidMotion.Button.Secondary" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/secondary_container</item>
        <item name="android:textColor">@color/on_secondary_container</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <style name="Widget.FluidMotion.Button.Tertiary" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/primary</item>
    </style>

    <!-- Card View Styles -->
    <style name="Widget.FluidMotion.CardView.Lowest" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/surface_container_lowest</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">2dp</item>
        <item name="strokeWidth">0dp</item>
    </style>

    <!-- App Theme -->
    <style name="Theme.FluidMotion" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="android:windowBackground">@color/surface</item>
    </style>
</resources>
