<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface">

    <!-- Top App Bar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/top_app_bar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        app:layout_constraintTop_toTopOf="parent"
        android:paddingHorizontal="16dp"
        android:background="#CCffffff"
        android:elevation="2dp">
        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="@color/primary"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tạo tài khoản"
            android:textColor="@color/on_surface"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp"
            app:layout_constraintStart_toEndOf="@id/btn_back"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/top_app_bar"
        app:layout_constraintBottom_toBottomOf="parent"
        android:fillViewport="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="24dp"
            android:paddingBottom="48dp">

            <!-- Visual Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginBottom="32dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tham gia Velocity"
                    android:textColor="@color/on_surface"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="280dp"
                    android:layout_height="wrap_content"
                    android:text="Trải nghiệm thế hệ dịch vụ đặt xe cao cấp tiếp theo."
                    android:textColor="@color/on_surface_variant"
                    android:textSize="15sp"
                    android:gravity="center" />
            </LinearLayout>

            <!-- Full Name -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Họ và tên" android:textColor="@color/on_surface_variant"
                android:textSize="14sp" android:textStyle="bold" android:layout_marginBottom="8dp" android:layout_marginStart="4dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_full_name"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                app:startIconDrawable="@android:drawable/ic_menu_myplaces"
                app:boxBackgroundColor="@color/surface_container_lowest"
                app:boxStrokeColor="@color/outline_variant"
                app:boxCornerRadiusTopStart="12dp" app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp" app:boxCornerRadiusBottomEnd="12dp"
                android:layout_marginBottom="20dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_full_name"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:hint="Nhập họ và tên đầy đủ" android:inputType="textPersonName"
                    android:paddingVertical="16dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Phone Number -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Số điện thoại" android:textColor="@color/on_surface_variant"
                android:textSize="14sp" android:textStyle="bold" android:layout_marginBottom="8dp" android:layout_marginStart="4dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_phone"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                app:startIconDrawable="@android:drawable/ic_menu_call"
                app:boxBackgroundColor="@color/surface_container_lowest"
                app:boxStrokeColor="@color/outline_variant"
                app:boxCornerRadiusTopStart="12dp" app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp" app:boxCornerRadiusBottomEnd="12dp"
                android:layout_marginBottom="20dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_phone"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:hint="Số điện thoại" android:inputType="phone"
                    android:paddingVertical="16dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Password -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Mật khẩu" android:textColor="@color/on_surface_variant"
                android:textSize="14sp" android:textStyle="bold" android:layout_marginBottom="8dp" android:layout_marginStart="4dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_password"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                app:startIconDrawable="@android:drawable/ic_secure"
                app:endIconMode="password_toggle"
                app:boxBackgroundColor="@color/surface_container_lowest"
                app:boxStrokeColor="@color/outline_variant"
                app:boxCornerRadiusTopStart="12dp" app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp" app:boxCornerRadiusBottomEnd="12dp"
                android:layout_marginBottom="20dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_password"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:hint="Tạo mật khẩu mạnh" android:inputType="textPassword"
                    android:paddingVertical="16dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Confirm Password -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Xác nhận mật khẩu" android:textColor="@color/on_surface_variant"
                android:textSize="14sp" android:textStyle="bold" android:layout_marginBottom="8dp" android:layout_marginStart="4dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_confirm_password"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                app:startIconDrawable="@android:drawable/ic_secure"
                app:boxBackgroundColor="@color/surface_container_lowest"
                app:boxStrokeColor="@color/outline_variant"
                app:boxCornerRadiusTopStart="12dp" app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp" app:boxCornerRadiusBottomEnd="12dp"
                android:layout_marginBottom="24dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_confirm_password"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:hint="Nhập lại mật khẩu" android:inputType="textPassword"
                    android:paddingVertical="16dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Terms & Conditions checkbox -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="32dp">
                <CheckBox
                    android:id="@+id/cb_terms"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="@color/primary" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tôi đồng ý với Điều khoản dịch vụ và Chính sách quyền riêng tư."
                    android:textColor="@color/on_surface_variant"
                    android:textSize="13sp"
                    android:layout_marginStart="8dp" />
            </LinearLayout>

            <!-- Register Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_register"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Đăng ký"
                android:textSize="17sp"
                android:textStyle="bold"
                style="@style/Widget.FluidMotion.Button.Primary"
                app:cornerRadius="12dp"
                android:layout_marginBottom="32dp" />

            <!-- Footer -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Đã có tài khoản? " android:textColor="@color/on_surface_variant" android:textSize="14sp" />
                <TextView android:id="@+id/tv_login" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Đăng nhập" android:textColor="@color/primary" android:textSize="14sp"
                    android:textStyle="bold" android:clickable="true" android:focusable="true" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
