<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface">

    <!-- Top App Bar -->
    <LinearLayout
        android:id="@+id/top_app_bar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:elevation="4dp"
        android:background="#CCffffff"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.cardview.widget.CardView android:layout_width="40dp" android:layout_height="40dp"
            app:cardCornerRadius="20dp" app:cardElevation="0dp" android:layout_marginEnd="12dp">
            <ImageView android:layout_width="match_parent" android:layout_height="match_parent"
                android:src="@android:drawable/ic_menu_today" android:padding="8dp" app:tint="@color/on_surface_variant" />
        </androidx.cardview.widget.CardView>

        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:text="GoDrive" android:textColor="@color/primary" android:textSize="20sp" android:textStyle="bold" />

        <!-- Online/Offline toggle -->
        <LinearLayout android:layout_width="wrap_content" android:layout_height="36dp"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:background="@drawable/bg_surface_low_16" android:paddingHorizontal="4dp">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_online"
                android:layout_width="wrap_content" android:layout_height="30dp"
                android:text="ONLINE" android:textSize="10sp" android:textColor="#2E7D32"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                app:cornerRadius="12dp" android:backgroundTint="#E8F5E9" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_offline"
                android:layout_width="wrap_content" android:layout_height="30dp"
                android:text="OFFLINE" android:textSize="10sp" android:textColor="@color/on_surface_variant"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                app:cornerRadius="12dp" android:backgroundTint="@android:color/transparent" />
        </LinearLayout>
    </LinearLayout>

    <!-- Map Background -->
    <FrameLayout
        android:id="@+id/map_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/top_app_bar"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@android:drawable/ic_menu_mapmode"
            android:scaleType="centerCrop"
            android:background="@color/surface_container_low"
            android:alpha="0.6" />

        <!-- Location dot -->
        <FrameLayout
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center">
            <View android:layout_width="48dp" android:layout_height="48dp"
                android:background="@drawable/circle_surface_highest" android:alpha="0.3" />
            <View android:layout_width="20dp" android:layout_height="20dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_primary_gradient_12" />
        </FrameLayout>
    </FrameLayout>

    <!-- Stats Overlay (top) -->
    <LinearLayout
        android:id="@+id/stats_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingTop="8dp"
        android:layout_marginTop="64dp"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Rides -->
        <androidx.cardview.widget.CardView
            android:layout_width="0dp" android:layout_height="80dp" android:layout_weight="1"
            app:cardCornerRadius="12dp" app:cardElevation="4dp" app:cardBackgroundColor="@color/surface_container_lowest"
            android:layout_marginEnd="6dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                android:orientation="vertical" android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="RIDES" android:textColor="@color/on_surface_variant" android:textSize="10sp" android:textStyle="bold" android:letterSpacing="0.05" />
                <TextView android:id="@+id/tv_ride_count" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="12" android:textColor="@color/primary" android:textSize="22sp" android:textStyle="bold" android:layout_marginTop="2dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Earnings -->
        <androidx.cardview.widget.CardView
            android:layout_width="0dp" android:layout_height="80dp" android:layout_weight="1"
            app:cardCornerRadius="12dp" app:cardElevation="4dp" app:cardBackgroundColor="@color/surface_container_lowest"
            android:layout_marginHorizontal="3dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                android:orientation="vertical" android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="EARNINGS" android:textColor="@color/on_surface_variant" android:textSize="10sp" android:textStyle="bold" android:letterSpacing="0.05" />
                <TextView android:id="@+id/tv_earnings" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="$184" android:textColor="@color/primary" android:textSize="22sp" android:textStyle="bold" android:layout_marginTop="2dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Hours -->
        <androidx.cardview.widget.CardView
            android:layout_width="0dp" android:layout_height="80dp" android:layout_weight="1"
            app:cardCornerRadius="12dp" app:cardElevation="4dp" app:cardBackgroundColor="@color/surface_container_lowest"
            android:layout_marginStart="6dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                android:orientation="vertical" android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="HOURS" android:textColor="@color/on_surface_variant" android:textSize="10sp" android:textStyle="bold" android:letterSpacing="0.05" />
                <TextView android:id="@+id/tv_hours" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="6.5" android:textColor="@color/primary" android:textSize="22sp" android:textStyle="bold" android:layout_marginTop="2dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>

    <!-- Ride Request Card (bottom overlay) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/ride_request_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="24dp"
        app:cardElevation="16dp"
        app:cardBackgroundColor="@color/surface_container_lowest"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="96dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Request Header -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingHorizontal="20dp" android:paddingVertical="12dp"
                android:background="@color/primary_fixed">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:text="Yêu cầu chuyến đi mới" android:textColor="@color/primary" android:textSize="14sp" android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="45s" android:textColor="@color/on_primary" android:textSize="12sp" android:textStyle="bold"
                    android:background="@drawable/bg_primary_gradient_12" android:paddingHorizontal="8dp" android:paddingVertical="4dp" />
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="20dp">

                <!-- Customer info + Fare -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="20dp">
                    <androidx.cardview.widget.CardView android:layout_width="48dp" android:layout_height="48dp"
                        app:cardCornerRadius="24dp" android:layout_marginEnd="12dp">
                        <ImageView android:layout_width="match_parent" android:layout_height="match_parent"
                            android:src="@android:drawable/ic_menu_myplaces" android:scaleType="centerCrop" />
                    </androidx.cardview.widget.CardView>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Sarah J." android:textColor="@color/on_surface" android:textSize="16sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="4.9 ★" android:textColor="@color/secondary" android:textSize="13sp" android:textStyle="bold" />
                    </LinearLayout>
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="end">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="$24.50" android:textColor="@color/on_surface" android:textSize="22sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="GIÁ ƯỚC TÍNH" android:textColor="@color/on_surface_variant" android:textSize="10sp" android:textStyle="bold" android:letterSpacing="0.05" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Pickup/Dropoff -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:layout_marginBottom="20dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
                        <View android:layout_width="12dp" android:layout_height="12dp"
                            android:background="@drawable/circle_surface_highest" android:layout_marginEnd="12dp" />
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="ĐÓN" android:textColor="@color/on_surface_variant" android:textSize="10sp" android:textStyle="bold" android:letterSpacing="0.05" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="282 Market St, Financial District" android:textColor="@color/on_surface" android:textSize="14sp" android:textStyle="bold" />
                        </LinearLayout>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="2.4 km" android:textColor="@color/on_surface_variant" android:textSize="12sp" />
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <View android:layout_width="12dp" android:layout_height="12dp"
                            android:background="@drawable/bg_primary_gradient_12" android:layout_marginEnd="12dp" />
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="TRẢ" android:textColor="@color/on_surface_variant" android:textSize="10sp" android:textStyle="bold" android:letterSpacing="0.05" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Sân bay Quốc tế, Terminal 2" android:textColor="@color/on_surface" android:textSize="14sp" android:textStyle="bold" />
                        </LinearLayout>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="18 phút" android:textColor="@color/on_surface_variant" android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Accept/Decline Buttons -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_decline_ride"
                        android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1"
                        android:text="Từ chối" android:textSize="15sp" android:textColor="@color/on_surface_variant"
                        android:backgroundTint="@color/surface_container_low"
                        style="@style/Widget.MaterialComponents.Button"
                        app:cornerRadius="12dp" android:layout_marginEnd="8dp" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_accept_ride"
                        android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1"
                        android:text="Chấp nhận" android:textSize="15sp"
                        style="@style/Widget.FluidMotion.Button.Primary"
                        app:cornerRadius="12dp" android:layout_marginStart="8dp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Bottom Navigation -->
    <LinearLayout
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@color/surface_container_lowest"
        android:elevation="8dp"
        android:paddingBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center" android:background="@drawable/bg_surface_low_16">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_today" app:tint="@color/primary" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="HOME" android:textColor="@color/primary" android:textSize="10sp" android:layout_marginTop="2dp" android:textStyle="bold" android:letterSpacing="0.1" />
        </LinearLayout>
        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center" android:clickable="true" android:focusable="true">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_manage" app:tint="@color/outline" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="THU NHẬP" android:textColor="@color/outline" android:textSize="10sp" android:layout_marginTop="2dp" android:letterSpacing="0.05" />
        </LinearLayout>
        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center" android:clickable="true" android:focusable="true">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_gallery" app:tint="@color/outline" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ĐÁNH GIÁ" android:textColor="@color/outline" android:textSize="10sp" android:layout_marginTop="2dp" android:letterSpacing="0.05" />
        </LinearLayout>
        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center" android:clickable="true" android:focusable="true">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_myplaces" app:tint="@color/outline" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="TÀI KHOẢN" android:textColor="@color/outline" android:textSize="10sp" android:layout_marginTop="2dp" android:letterSpacing="0.05" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>